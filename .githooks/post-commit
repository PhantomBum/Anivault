#!/bin/sh
# Auto-push the current branch to origin after every commit.
# Enable once from repo root: git config core.hooksPath .githooks
# Or run: powershell -File scripts/setup-git-hooks.ps1

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || exit 0
if [ "$branch" = "HEAD" ]; then
  exit 0
fi

echo "post-commit: pushing $branch to origin..."
git push origin "$branch"
